{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "harness/hooks/validate-schema.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "generator",
        "hooks": [
          {
            "type": "command",
            "command": "python harness/hooks/on-generator-stop.py"
          }
        ]
      },
      {
        "matcher": "evaluator",
        "hooks": [
          {
            "type": "command",
            "command": "python harness/hooks/on-evaluator-stop.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python harness/hooks/on-stop.py"
          }
        ]
      }
    ]
  }
}
